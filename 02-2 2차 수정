    const $ = (selector) => document.querySelector(selector);
    const $$ = (selector) => [...document.querySelectorAll(selector)];

    const state = {
      search: "",
      book: "all",
      topic: "all",
      view: "cards",
      saved: JSON.parse(localStorage.getItem("analectsSavedIds") || "[]"),
      fontScale: Number(localStorage.getItem("analectsFontScale") || "1"),
      theme: localStorage.getItem("analectsTheme") || "light"
    };

    const dateFormatter = new Intl.DateTimeFormat("ko-KR", {
      year: "numeric",
      month: "long",
      day: "numeric",
      weekday: "long"
    });

    function dayNumber(date = new Date()) {
      const start = new Date(date.getFullYear(), 0, 0);
      const diff = date - start + ((start.getTimezoneOffset() - date.getTimezoneOffset()) * 60 * 1000);
      return Math.floor(diff / (1000 * 60 * 60 * 24));
    }

    function verseForDate(date = new Date()) {
      const index = (dayNumber(date) - 1) % analectsData.length;
      return analectsData[index];
    }

    function uniqueBooks() {
      const map = new Map();
      analectsData.forEach(v => map.set(v.book, v.bookKo));
      return [...map.entries()].map(([book, bookKo]) => ({ book, bookKo }));
    }

    function uniqueTopics() {
      return [...new Set(analectsData.flatMap(v => v.topics))].sort((a, b) => a.localeCompare(b, "ko"));
    }

    function isSaved(id) {
      return state.saved.includes(id);
    }

    function saveState() {
      localStorage.setItem("analectsSavedIds", JSON.stringify(state.saved));
      localStorage.setItem("analectsFontScale", String(state.fontScale));
      localStorage.setItem("analectsTheme", state.theme);
    }

    function showToast(message) {
      const toast = $("#toast");
      toast.textContent = message;
      toast.classList.add("show");
      setTimeout(() => toast.classList.remove("show"), 1500);
    }

    function copyVerse(verse) {
      const text = `${verse.original}\n${verse.translation}\n- ${verse.bookKo} ${verse.chapter}`;
      navigator.clipboard?.writeText(text).then(() => showToast("구절을 복사했습니다."));
    }

    function toggleSave(id) {
      if (isSaved(id)) {
        state.saved = state.saved.filter(savedId => savedId !== id);
        showToast("저장을 해제했습니다.");
      } else {
        state.saved.push(id);
        showToast("구절을 저장했습니다.");
      }
      saveState();
      renderAll();
    }

    function populateControls() {
      const bookSelect = $("#bookSelect");
      const topicSelect = $("#topicSelect");
      const topicChips = $("#topicChips");

      uniqueBooks().forEach(({ book, bookKo }) => {
        const option = document.createElement("option");
        option.value = book;
        option.textContent = `${bookKo} (${countByBook(book)}개)`;
        bookSelect.appendChild(option);
      });

      uniqueTopics().forEach(topic => {
        const option = document.createElement("option");
        option.value = topic;
        option.textContent = `${topic} (${countByTopic(topic)}개)`;
        topicSelect.appendChild(option);

        const chip = document.createElement("button");
        chip.className = "chip";
        chip.type = "button";
        chip.textContent = topic;
        chip.dataset.topic = topic;
        chip.addEventListener("click", () => {
          state.topic = state.topic === topic ? "all" : topic;
          topicSelect.value = state.topic;
          renderAll();
        });
        topicChips.appendChild(chip);
      });
    }

    function countByBook(book) {
      return analectsData.filter(v => v.book === book).length;
    }

    function countByTopic(topic) {
      return analectsData.filter(v => v.topics.includes(topic)).length;
    }

    function filteredData() {
      const keyword = state.search.trim().toLowerCase();
      return analectsData.filter(verse => {
        const bookMatch = state.book === "all" || verse.book === state.book;
        const topicMatch = state.topic === "all" || verse.topics.includes(state.topic);
        const searchTarget = [
          verse.original,
          verse.translation,
          verse.book,
          verse.bookKo,
          verse.chapter,
          verse.note,
          ...verse.topics
        ].join(" ").toLowerCase();
        const searchMatch = !keyword || searchTarget.includes(keyword);
        return bookMatch && topicMatch && searchMatch;
      });
    }

    function verseCard(verse) {
      const article = document.createElement("article");
      article.className = "verse-card";
      article.innerHTML = `
        <div class="verse-meta">
          <span class="book-badge">${verse.bookKo} ${verse.chapter}</span>
          <span>${verse.book}</span>
        </div>
        <div class="hanja">${verse.original}</div>
        <p class="translation">${verse.translation}</p>
        <div class="explain">${verse.note}</div>
        <div class="tagline">${verse.topics.map(topic => `<span class="pill"># ${topic}</span>`).join("")}</div>
        <div class="card-actions">
          <button class="small-btn ${isSaved(verse.id) ? "saved" : ""}" type="button" data-action="save" data-id="${verse.id}">${isSaved(verse.id) ? "♥ 저장됨" : "♡ 저장"}</button>
          <button class="small-btn" type="button" data-action="copy" data-id="${verse.id}">복사</button>
          <button class="small-btn" type="button" data-action="focus" data-id="${verse.id}">오늘 카드로 보기</button>
        </div>
      `;
      return article;
    }

    function renderCards(data = filteredData()) {
      const area = $("#contentArea");
      area.className = "cards";
      area.innerHTML = "";

      if (!data.length) {
        area.innerHTML = `<div class="empty">검색 결과가 없습니다.<br />검색어를 줄이거나 필터를 초기화해 보세요.</div>`;
        return;
      }

      data.forEach(verse => area.appendChild(verseCard(verse)));
    }

    function renderBooks() {
      const area = $("#contentArea");
      area.className = "book-grid";
      area.innerHTML = "";
      uniqueBooks().forEach(({ book, bookKo }) => {
        const card = document.createElement("button");
        card.type = "button";
        card.className = "summary-card";
        card.innerHTML = `<strong>${bookKo}</strong><span>${book} · ${countByBook(book)}개 구절</span>`;
        card.addEventListener("click", () => {
          state.book = book;
          state.view = "cards";
          $("#bookSelect").value = book;
          renderAll();
        });
        area.appendChild(card);
      });
    }

    function renderTopics() {
      const area = $("#contentArea");
      area.className = "topic-grid";
      area.innerHTML = "";
      uniqueTopics().forEach(topic => {
        const card = document.createElement("button");
        card.type = "button";
        card.className = "summary-card";
        card.innerHTML = `<strong>${topic}</strong><span>${countByTopic(topic)}개 구절</span>`;
        card.addEventListener("click", () => {
          state.topic = topic;
          state.view = "cards";
          $("#topicSelect").value = topic;
          renderAll();
        });
        area.appendChild(card);
      });
    }

    function renderSaved() {
      const savedVerses = analectsData.filter(v => isSaved(v.id));
      renderCards(savedVerses);
      if (!savedVerses.length) {
        $("#contentArea").innerHTML = `<div class="empty">아직 저장한 구절이 없습니다.<br />마음에 드는 구절의 ♡ 저장을 눌러 보세요.</div>`;
      }
    }

    function renderToday(verse = verseForDate()) {
      $("#todayDate").textContent = dateFormatter.format(new Date());
      $("#todayOriginal").textContent = verse.original;
      $("#todayTranslation").textContent = verse.translation;
      $("#todayTags").innerHTML = [
        `<span class="pill">${verse.bookKo} ${verse.chapter}</span>`,
        ...verse.topics.map(topic => `<span class="pill"># ${topic}</span>`)
      ].join("");
      $("#todaySaveBtn").textContent = isSaved(verse.id) ? "♥ 저장됨" : "♡ 저장";
      $("#todaySaveBtn").classList.toggle("saved", isSaved(verse.id));
      $("#todaySaveBtn").dataset.id = verse.id;
      $("#todayCopyBtn").dataset.id = verse.id;
    }

    function renderHistory() {
      const list = $("#historyList");
      list.innerHTML = "";
      const today = new Date();
      for (let i = 0; i < 30; i++) {
        const date = new Date(today);
        date.setDate(today.getDate() - i);
        const verse = verseForDate(date);
        const item = document.createElement("button");
        item.type = "button";
        item.className = "history-item";
        item.innerHTML = `
          <span class="history-date">${dateFormatter.format(date)}</span>
          <span class="history-text">${verse.bookKo} ${verse.chapter} · ${verse.translation.slice(0, 42)}${verse.translation.length > 42 ? "..." : ""}</span>
        `;
        item.addEventListener("click", () => {
          renderToday(verse);
          document.querySelector("header.hero").scrollIntoView({ behavior: "smooth", block: "start" });
        });
        list.appendChild(item);
      }
    }

    function renderStats() {
      $("#statVerses").textContent = analectsData.length;
      $("#statBooks").textContent = uniqueBooks().length;
      $("#statTopics").textContent = uniqueTopics().length;
      $("#statSaved").textContent = state.saved.length;
      $("#resultCount").textContent = state.view === "saved" ? state.saved.length : filteredData().length;
    }

    function renderTabs() {
      $$(".tab").forEach(tab => tab.classList.toggle("active", tab.dataset.view === state.view));
      $$(".chip").forEach(chip => chip.classList.toggle("active", chip.dataset.topic === state.topic));
    }

    function renderMain() {
      if (state.view === "books") renderBooks();
      else if (state.view === "topics") renderTopics();
      else if (state.view === "saved") renderSaved();
      else renderCards();
    }

    function applyPreferences() {
      document.documentElement.dataset.theme = state.theme;
      document.documentElement.style.setProperty("--font-scale", state.fontScale);
      $("#themeBtn").textContent = state.theme === "dark" ? "☀️ 라이트 모드" : "🌙 다크 모드";
    }

    function renderAll() {
      renderStats();
      renderTabs();
      renderToday();
      renderHistory();
      renderMain();
      applyPreferences();
    }

    function bindEvents() {
      $("#searchInput").addEventListener("input", e => {
        state.search = e.target.value;
        state.view = "cards";
        renderAll();
      });

      $("#bookSelect").addEventListener("change", e => {
        state.book = e.target.value;
        state.view = "cards";
        renderAll();
      });

      $("#topicSelect").addEventListener("change", e => {
        state.topic = e.target.value;
        state.view = "cards";
        renderAll();
      });

      $("#resetBtn").addEventListener("click", () => {
        state.search = "";
        state.book = "all";
        state.topic = "all";
        state.view = "cards";
        $("#searchInput").value = "";
        $("#bookSelect").value = "all";
        $("#topicSelect").value = "all";
        renderAll();
      });

      $$(".tab").forEach(tab => {
        tab.addEventListener("click", () => {
          state.view = tab.dataset.view;
          renderAll();
        });
      });

      $("#themeBtn").addEventListener("click", () => {
        state.theme = state.theme === "dark" ? "light" : "dark";
        saveState();
        applyPreferences();
      });

      $("#fontDownBtn").addEventListener("click", () => {
        state.fontScale = Math.max(.88, +(state.fontScale - .06).toFixed(2));
        saveState();
        applyPreferences();
      });

      $("#fontUpBtn").addEventListener("click", () => {
        state.fontScale = Math.min(1.24, +(state.fontScale + .06).toFixed(2));
        saveState();
        applyPreferences();
      });

      $("#randomBtn").addEventListener("click", () => {
        const verse = analectsData[Math.floor(Math.random() * analectsData.length)];
        renderToday(verse);
        showToast("무작위 구절을 보여드립니다.");
      });

      $("#todaySaveBtn").addEventListener("click", e => toggleSave(Number(e.currentTarget.dataset.id)));
      $("#todayCopyBtn").addEventListener("click", e => {
        const verse = analectsData.find(v => v.id === Number(e.currentTarget.dataset.id));
        copyVerse(verse);
      });

      $("#contentArea").addEventListener("click", e => {
        const button = e.target.closest("button[data-action]");
        if (!button) return;
        const id = Number(button.dataset.id);
        const verse = analectsData.find(v => v.id === id);
        if (button.dataset.action === "save") toggleSave(id);
        if (button.dataset.action === "copy") copyVerse(verse);
        if (button.dataset.action === "focus") {
          renderToday(verse);
          document.querySelector("header.hero").scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    }

    function init() {
      populateControls();
      bindEvents();
      applyPreferences();
      renderAll();
    }

    init();
  </script>
</body>
</html>
