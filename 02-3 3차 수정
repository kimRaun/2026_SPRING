function calculateStreak(days) {
  let streak = 0;
  for (let i = 0; i < 365; i++) {
    if (days.has(daysAgoKey(i))) streak += 1;
    else break;
  }
  return streak;
}

function calculateBestStreak(days) {
  const sorted = [...days].sort();
  let best = 0, current = 0, prev = null;
  sorted.forEach(key => {
    const time = new Date(key + "T00:00:00Z").getTime();
    if (prev === null || time - prev === 86400000) current += 1;
    else current = 1;
    best = Math.max(best, current);
    prev = time;
  });
  return best;
}

function completeToday() {
  const days = getStudyDays();
  const today = dateKey();
  const already = days.has(today);
  days.add(today);
  saveStudyDays(days);
  renderLearning();
  updateStats();
  toast(already ? "오늘 학습은 이미 기록되어 있습니다." : "오늘 학습 완료! 기록에 저장했습니다.");
}

function renderLearning() {
  const days = getStudyDays();
  const streak = calculateStreak(days);
  $("recordStreak").textContent = `${streak}일`;
  $("recordTotal").textContent = `${days.size}일`;
  $("recordBest").textContent = `${calculateBestStreak(days)}일`;
  if ($("statStreak")) $("statStreak").textContent = streak;

  const labels = [];
  for (let i = 13; i >= 0; i--) {
    const key = daysAgoKey(i);
    const [y, m, d] = key.split("-");
    labels.push(`<div class="day-dot ${days.has(key) ? "done" : ""}" title="${key}">
      ${Number(m)}/${Number(d)}<br>${days.has(key) ? "완료" : "—"}
    </div>`);
  }
  $("studyCalendar").innerHTML = labels.join("");
  $("studyMemo").value = localStorage.getItem(MEMO_KEY) || "";
}

function saveMemo() {
  localStorage.setItem(MEMO_KEY, $("studyMemo").value);
  toast("메모를 저장했습니다.");
}

function getBookmarks() {
  try { return new Set(JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]")); }
  catch { return new Set(); }
}

function saveBookmarks(set) {
  localStorage.setItem(STORAGE_KEY, JSON.stringify([...set]));
}

function kstDate(date = new Date()) {
  return new Date(date.getTime() + KST_OFFSET);
}

function dateKey(date = new Date()) {
  const d = kstDate(date);
  return d.toISOString().slice(0,10);
}

function formatKoreanDate(key) {
  const [y,m,d] = key.split("-");
  return `${Number(m)}월 ${Number(d)}일`;
}

function indexForDate(key) {
  const days = Math.floor(new Date(key + "T00:00:00Z").getTime() / 86400000);
  return ((days % analectsData.length) + analectsData.length) % analectsData.length;
}

function verseForDate(key) {
  return analectsData[indexForDate(key)];
}

function tagHTML(verse) {
  return [`<span class="tag book">${verse.book} ${verse.verseNumber}</span>`, ...verse.themes.map(t => `<span class="tag">${t}</span>`)].join("");
}

function verseHTML(verse, compact=false) {
  const bookmarks = getBookmarks();
  const saved = bookmarks.has(String(verse.id));
  return `
    <div class="verse-card">
      <div class="verse-head">
        <div>
          <div class="verse-title">${verse.title}</div>
          <div class="mini">${verse.book} · ${verse.themes.join(" · ")}</div>
        </div>
        <div class="verse-actions">
          <button class="tiny-btn ${saved ? "active" : ""}" onclick="toggleBookmark(${verse.id})">${saved ? "★ 저장됨" : "☆ 저장"}</button>
          <button class="tiny-btn" onclick="copyVerse(${verse.id})">복사</button>
        </div>
      </div>
      <div class="original">${verse.original}</div>
      <p class="translation">${verse.translation}</p>
      <div class="meta-row">${tagHTML(verse)}</div>
    </div>
  `;
}

function renderToday() {
  const key = dateKey();
  const verse = verseForDate(key);
  selectedVerse = verse;
  $("todayDate").textContent = formatKoreanDate(key);
  $("todayContent").innerHTML = verseHTML(verse, true);
  renderSelected(verse, `오늘의 논어 · ${formatKoreanDate(key)}`);
}

function renderSelected(verse, hint = "선택한 구절") {
  selectedVerse = verse;
  $("selectedHint").textContent = hint;
  $("selectedVerse").innerHTML = verseHTML(verse);
}

function renderHistory() {
  const list = [];
  const today = new Date();
  for (let i = 0; i < 30; i++) {
    const d = new Date(today.getTime() - i * 86400000);
    const key = dateKey(d);
    const verse = verseForDate(key);
    list.push(`<button onclick="selectHistory('${key}')" title="${verse.title}">
      <strong>${formatKoreanDate(key)}</strong>
      <small>${verse.book} ${verse.verseNumber} · ${verse.themes[0] || ""}</small>
    </button>`);
  }
  $("historyList").innerHTML = list.join("");
}

function selectHistory(key) {
  renderSelected(verseForDate(key), `최근 30일 기록 · ${formatKoreanDate(key)}`);
  $("selectedVerse").scrollIntoView({ behavior: "smooth", block: "center" });
}

function allThemes() {
  return [...new Set(analectsData.flatMap(v => v.themes || []))].sort((a,b)=>a.localeCompare(b, "ko"));
}

function allBooks() {
  const map = new Map();
  analectsData.forEach(v => {
    if (!map.has(v.book)) map.set(v.book, { book: v.book, bookIndex: v.bookIndex, count: 0 });
    map.get(v.book).count += 1;
  });
  return [...map.values()].sort((a,b) => a.bookIndex - b.bookIndex);
}

function populateFilters() {
  $("themeFilter").innerHTML = `<option value="">모든 주제</option>` + allThemes().map(t => `<option value="${t}">${t}</option>`).join("");
  $("bookFilter").innerHTML = `<option value="">모든 편</option>` + allBooks().map(b => `<option value="${b.book}">${b.book} (${b.count})</option>`).join("");
}

function renderThemeCards() {
  $("themeCards").innerHTML = allThemes().map(theme => {
    const verses = analectsData.filter(v => v.themes.includes(theme));
    const sample = verses[0];
    return `<button class="theme-card" onclick="applyTheme('${theme}')">
      <h3>${theme}</h3>
      <div class="count">${verses.length}개 구절</div>
      <div class="mini">${sample ? sample.translation.slice(0, 48) + "…" : ""}</div>
    </button>`;
  }).join("");
}

function renderBookCards() {
  $("bookCards").innerHTML = allBooks().map(book => {
    const verses = analectsData.filter(v => v.book === book.book);
    return `<button class="book-card" onclick="applyBook('${book.book}')">
      <h3>${book.book}</h3>
      <div class="count">${book.count}개 구절</div>
      <div class="mini">${verses.map(v => v.verseNumber).slice(0,5).join(", ")}${verses.length > 5 ? "…" : ""}</div>
    </button>`;
  }).join("");
}

function filteredVerses() {
  const q = $("searchInput").value.trim().toLowerCase();
  const theme = $("themeFilter").value;
  const book = $("bookFilter").value;
  const bookmarks = getBookmarks();

  return analectsData.filter(v => {
    const haystack = `${v.original} ${v.translation} ${v.title} ${v.book} ${v.themes.join(" ")}`.toLowerCase();
    return (!q || haystack.includes(q))
      && (!theme || v.themes.includes(theme))
      && (!book || v.book === book)
      && (!bookmarkedOnly || bookmarks.has(String(v.id)));
  });
}

function renderVerseList() {
  const verses = filteredVerses();
  $("resultSummary").textContent = `${verses.length}개 구절이 표시됩니다.`;
  $("verseList").innerHTML = verses.length
    ? verses.map(v => verseHTML(v)).join("")
    : `<div class="empty">조건에 맞는 구절이 없습니다. 검색어나 필터를 조정해 보세요.</div>`;
  updateStats();
}

function applyTheme(theme) {
  $("themeFilter").value = theme;
  renderVerseList();
  $("all-verses").scrollIntoView({behavior:"smooth"});
}

function applyBook(book) {
  $("bookFilter").value = book;
  renderVerseList();
  $("all-verses").scrollIntoView({behavior:"smooth"});
}

function toggleBookmark(id) {
  const bookmarks = getBookmarks();
  const key = String(id);
  const saved = bookmarks.has(key);
  saved ? bookmarks.delete(key) : bookmarks.add(key);
  saveBookmarks(bookmarks);
  toast(saved ? "저장을 해제했습니다." : "구절을 저장했습니다.");
  renderVerseList();
  renderToday();
  if (selectedVerse) renderSelected(selectedVerse, $("selectedHint").textContent);
}

function copyVerse(id) {
  const v = analectsData.find(item => item.id === id);
  const text = `${v.title}\n${v.original}\n${v.translation}`;
  navigator.clipboard?.writeText(text).then(() => toast("구절을 복사했습니다."));
}


let currentQuiz = null;
let quizLocked = false;

function shuffle(array) {
  return [...array].sort(() => Math.random() - 0.5);
}

function pickRandom(exceptId = null) {
  const pool = analectsData.filter(v => v.id !== exceptId);
  return pool[Math.floor(Math.random() * pool.length)];
}

function makeQuiz() {
  const verse = pickRandom();
  const type = Math.floor(Math.random() * 3);
  let prompt, source, answer, options, label;

  if (type === 0) {
    label = "뜻 맞히기";
    prompt = "다음 원문의 알맞은 해석은?";
    source = verse.original;
    answer = verse.translation;
    options = shuffle([answer, pickRandom(verse.id).translation, pickRandom(verse.id).translation, pickRandom(verse.id).translation]);
  } else if (type === 1) {
    label = "주제 맞히기";
    prompt = "다음 구절과 가장 가까운 주제는?";
    source = verse.translation;
    answer = verse.themes[0];
    options = shuffle([answer, ...shuffle(allThemes().filter(t => t !== answer)).slice(0, 3)]);
  } else {
    label = "원문 찾기";
    prompt = "다음 해석에 맞는 원문은?";
    source = verse.translation;
    answer = verse.original;
    options = shuffle([answer, pickRandom(verse.id).original, pickRandom(verse.id).original, pickRandom(verse.id).original]);
  }

  currentQuiz = { verse, answer };
  quizLocked = false;
  $("quizCard").innerHTML = `
    <div class="quiz-question">
      <div class="quiz-type">${label}</div>
      <div class="quiz-prompt">${prompt}</div>
      <div class="quiz-source">${source}</div>
    </div>
    <div class="quiz-options">
      ${options.map((option, index) => `<button class="quiz-option" data-answer="${encodeURIComponent(option)}">${index + 1}. ${option}</button>`).join("")}
    </div>
    <div class="quiz-result" id="quizResult">정답을 골라보세요.</div>
    <div class="quiz-actions">
      <button class="btn primary" id="nextQuiz">다음 문제</button>
      <button class="btn" id="resetQuizScore">점수 초기화</button>
    </div>
  `;
  $("quizCard").querySelectorAll(".quiz-option").forEach(btn => btn.addEventListener("click", checkQuiz));
  $("nextQuiz").addEventListener("click", makeQuiz);
  $("resetQuizScore").addEventListener("click", () => {
    saveQuizScore({ total: 0, correct: 0 });
    renderQuizScore();
    toast("퀴즈 점수를 초기화했습니다.");
  });
  renderQuizScore();
}

function checkQuiz(event) {
  if (quizLocked) return;
  quizLocked = true;
  const picked = decodeURIComponent(event.currentTarget.dataset.answer);
  const correct = picked === currentQuiz.answer;
  const score = getQuizScore();
  score.total += 1;
  if (correct) score.correct += 1;
  saveQuizScore(score);

  $("quizCard").querySelectorAll(".quiz-option").forEach(btn => {
    const value = decodeURIComponent(btn.dataset.answer);
    if (value === currentQuiz.answer) btn.classList.add("correct");
    else if (btn === event.currentTarget) btn.classList.add("wrong");
  });

  $("quizResult").textContent = correct
    ? `정답입니다! ${currentQuiz.verse.title} 구절입니다.`
    : `아쉬워요. 정답은 ${currentQuiz.verse.title}입니다.`;
  renderQuizScore();
}

function renderQuizScore() {
  const score = getQuizScore();
  const rate = score.total ? Math.round(score.correct / score.total * 100) : 0;
  $("quizScore").textContent = `${score.total}문제 풀이 · 정답 ${score.correct}개 · 정답률 ${rate}%`;
}

function updateStats() {
  const bookmarks = getBookmarks();
  $("statVerses").textContent = analectsData.length;
  $("statBooks").textContent = allBooks().length;
  $("statThemes").textContent = allThemes().length;
  $("statBookmarks").textContent = bookmarks.size;
  if ($("statStreak")) $("statStreak").textContent = calculateStreak(getStudyDays());
  const pct = analectsData.length ? Math.round((bookmarks.size / analectsData.length) * 100) : 0;
  $("progressText").textContent = `저장한 구절 ${bookmarks.size}개 · 전체의 ${pct}%`;
  $("progressBar").style.width = `${pct}%`;
}

function resetFilters() {
  $("searchInput").value = "";
  $("themeFilter").value = "";
  $("bookFilter").value = "";
  bookmarkedOnly = false;
  $("bookmarkedOnly").classList.remove("active");
  renderVerseList();
}

function initPreferences() {
  const savedTheme = localStorage.getItem("analects_theme") || "light";
  document.documentElement.dataset.theme = savedTheme;
  $("themeToggle").textContent = savedTheme === "dark" ? "☀️" : "🌙";

  const scale = localStorage.getItem("analects_font_scale") || "1";
  document.documentElement.style.setProperty("--font-scale", scale);
}

function changeFont(delta) {
  const current = parseFloat(getComputedStyle(document.documentElement).getPropertyValue("--font-scale")) || 1;
  const next = Math.min(1.18, Math.max(.92, +(current + delta).toFixed(2)));
  document.documentElement.style.setProperty("--font-scale", next);
  localStorage.setItem("analects_font_scale", next);
}

function init() {
  initPreferences();
  populateFilters();
  renderToday();
  renderHistory();
  renderThemeCards();
  renderBookCards();
  renderVerseList();
  updateStats();
  renderLearning();
  makeQuiz();

  $("searchInput").addEventListener("input", renderVerseList);
  $("themeFilter").addEventListener("change", renderVerseList);
  $("bookFilter").addEventListener("change", renderVerseList);
  $("resetBtn").addEventListener("click", resetFilters);
  $("completeToday").addEventListener("click", completeToday);
  $("saveMemo").addEventListener("click", saveMemo);
  $("randomBtn").addEventListener("click", () => {
    const verse = analectsData[Math.floor(Math.random() * analectsData.length)];
    renderSelected(verse, "무작위 구절");
    $("selectedVerse").scrollIntoView({behavior:"smooth", block:"center"});
  });
  $("todayCopy").addEventListener("click", () => selectedVerse && copyVerse(selectedVerse.id));
  $("bookmarkedOnly").addEventListener("click", () => {
    bookmarkedOnly = !bookmarkedOnly;
    $("bookmarkedOnly").classList.toggle("active", bookmarkedOnly);
    renderVerseList();
  });
  $("themeToggle").addEventListener("click", () => {
    const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
    document.documentElement.dataset.theme = next;
    localStorage.setItem("analects_theme", next);
    $("themeToggle").textContent = next === "dark" ? "☀️" : "🌙";
  });
  $("fontUp").addEventListener("click", () => changeFont(.04));
  $("fontDown").addEventListener("click", () => changeFont(-.04));
}

init();
  </script>
</body>
</html>
