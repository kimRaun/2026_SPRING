const TOTAL_VERSES_PLACEHOLDER = 499;
const TOTAL_BOOKS_PLACEHOLDER = 20;
const ALL_THEMES = ["배움","친구·관계","효·가족","예절","군자·수양","정치·리더십","신의·말","인·배려","실천·행동","즐거움"];

function escapeHtml(str) {
  return String(str || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function formatDate(date) {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, '0');
  const d = String(date.getDate()).padStart(2, '0');
  return `${y}-${m}-${d}`;
}

function dateSeed(date) {
  const start = new Date('2026-01-01T00:00:00');
  return Math.floor((date - start) / (1000 * 60 * 60 * 24));
}

function getVerseByDate(date) {
  const index = ((dateSeed(date) % analectsData.length) + analectsData.length) % analectsData.length;
  return analectsData[index];
}

function verseCardHtml(verse, showFull = true) {
  return `
    <div class="verse-id">${escapeHtml(verse.title)}</div>
    <div class="quote-original">${escapeHtml(verse.original)}</div>
    <div class="quote-block quote-translation"><strong>번역</strong><br />${escapeHtml(verse.translation)}</div>
    ${showFull ? `<div class="quote-block quote-themes"><strong>주제</strong><br />${verse.themes.map(t => `#${escapeHtml(t)}`).join(' ')}</div>` : ''}
    <div class="meta-row">
      <span class="meta-pill">편: ${escapeHtml(verse.book)}</span>
      <span class="meta-pill">번호: ${escapeHtml(verse.verseNumber)}</span>
      ${verse.themes.map(theme => `<span class="meta-pill">${escapeHtml(theme)}</span>`).join('')}
    </div>
  `;
}

function renderToday() {
  const today = new Date();
  const verse = getVerseByDate(today);
  document.getElementById('todayCard').innerHTML = `
    <span class="topic-tag">${formatDate(today)} 오늘의 논어</span>
    ${verseCardHtml(verse, true)}
  `;
}

function renderHistory(days = 30) {
  const list = document.getElementById('historyList');
  const today = new Date();
  const items = [];
  for (let i = 1; i <= days; i++) {
    const d = new Date(today);
    d.setDate(today.getDate() - i);
    const verse = getVerseByDate(d);
    items.push(`
      <div class="history-item" onclick="focusVerse(${verse.id})">
        <div class="history-date">${formatDate(d)}</div>
        <div><strong>${escapeHtml(verse.title)}</strong></div>
        <div class="muted">${escapeHtml(verse.translation.slice(0, 56))}...</div>
      </div>
    `);
  }
  list.innerHTML = items.join('');
}

function getThemeStats() {
  const map = new Map();
  ALL_THEMES.forEach(theme => map.set(theme, 0));
  analectsData.forEach(v => (v.themes || []).forEach(t => map.set(t, (map.get(t) || 0) + 1)));
  return [...map.entries()].sort((a, b) => b[1] - a[1]);
}

function renderThemes() {
  const stats = getThemeStats();
  document.getElementById('themeList').innerHTML = stats.map(([theme, count]) => `
    <div class="theme-item" onclick="applyTheme('${theme.replace(/'/g, "\\'")}')">
      <strong>${escapeHtml(theme)}</strong> <span class="muted">(${count}개)</span>
    </div>
  `).join('');
}

function renderThemePreview(theme) {
  const matches = analectsData.filter(v => v.themes.includes(theme)).slice(0, 3);
  const el = document.getElementById('themePreview');
  if (!matches.length) {
    el.innerHTML = '해당 주제의 구절이 없습니다.';
    return;
  }
  el.innerHTML = `
    <span class="topic-tag">선택 주제: ${escapeHtml(theme)}</span>
    ${matches.map(v => `<div style="margin-bottom:16px;">${verseCardHtml(v, false)}</div>`).join('')}
  `;
}

function renderBooks() {
  const map = new Map();
  analectsData.forEach(v => {
    if (!map.has(v.book)) map.set(v.book, []);
    map.get(v.book).push(v);
  });
  const books = [...map.entries()].sort((a, b) => a[1][0].bookIndex - b[1][0].bookIndex);
  document.getElementById('bookList').innerHTML = books.map(([book, verses]) => `
    <div class="book-item" onclick="setBookFilter('${book.replace(/'/g, "\\'")}')">
      <strong>${escapeHtml(book)}</strong> <span class="muted">(${verses.length}개)</span><br />
      <span class="muted">대표 구절: ${escapeHtml(verses[0].translation.slice(0, 80))}...</span>
    </div>
  `).join('');
}

function populateFilters() {
  const themeFilter = document.getElementById('themeFilter');
  const bookFilter = document.getElementById('bookFilter');
  ALL_THEMES.forEach(theme => {
    const opt = document.createElement('option');
    opt.value = theme; opt.textContent = theme;
    themeFilter.appendChild(opt);
  });
  [...new Set(analectsData.map(v => v.book))].forEach(book => {
    const opt = document.createElement('option');
    opt.value = book; opt.textContent = book;
    bookFilter.appendChild(opt);
  });
}

function filteredVerses() {
  const q = document.getElementById('searchInput').value.trim().toLowerCase();
  const theme = document.getElementById('themeFilter').value;
  const book = document.getElementById('bookFilter').value;
  return analectsData.filter(v => {
    const text = [v.title, v.original, v.translation, ...(v.themes || [])].join(' ').toLowerCase();
    const qMatch = !q || text.includes(q);
    const themeMatch = !theme || v.themes.includes(theme);
    const bookMatch = !book || v.book === book;
    return qMatch && themeMatch && bookMatch;
  });
}

function renderVerseList() {
  const list = document.getElementById('verseList');
  const info = document.getElementById('resultInfo');
  const verses = filteredVerses();
  info.textContent = `검색 결과 ${verses.length}개`;
  if (!verses.length) {
    list.innerHTML = `<div class="empty-state">검색 결과가 없습니다. 키워드나 주제를 바꿔보세요.</div>`;
    return;
  }
  list.innerHTML = verses.map(v => `
    <article class="verse-card" id="verse-${v.id}">
      ${verseCardHtml(v, true)}
    </article>
  `).join('');
}

function focusVerse(id) {
  const verse = analectsData.find(v => v.id === id);
  if (!verse) return;
  document.getElementById('searchInput').value = verse.title;
  document.getElementById('themeFilter').value = '';
  document.getElementById('bookFilter').value = verse.book;
  renderVerseList();
  document.getElementById('all-verses').scrollIntoView({ behavior: 'smooth' });
}

function applyTheme(theme) {
  document.getElementById('themeFilter').value = theme;
  renderThemePreview(theme);
  renderVerseList();
  document.getElementById('all-verses').scrollIntoView({ behavior: 'smooth' });
}

function setBookFilter(book) {
  document.getElementById('bookFilter').value = book;
  renderVerseList();
  document.getElementById('all-verses').scrollIntoView({ behavior: 'smooth' });
}

function initStats() {
  document.getElementById('statVerses').textContent = TOTAL_VERSES_PLACEHOLDER;
  document.getElementById('statBooks').textContent = TOTAL_BOOKS_PLACEHOLDER;
  document.getElementById('statThemes').textContent = ALL_THEMES.length;
}

function init() {
  initStats();
  populateFilters();
  renderToday();
  renderHistory();
  renderThemes();
  renderBooks();
  renderThemePreview('배움');
  renderVerseList();
}

init();
  </script>
